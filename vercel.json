{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["rules/**", "src/**"]
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/v1/(.*)", "dest": "/api/index.ts" },
    { "src": "/assets/(.*)", "dest": "/frontend/assets/$1" },
    { "src": "/favicon\\.(ico|svg|png)", "dest": "/frontend/favicon.$1" },
    { "src": "/(.*)", "dest": "/frontend/index.html" }
  ]
}
