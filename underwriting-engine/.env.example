# ============================================================
# Personal Loan Underwriting Engine — Environment Config
# Copy to .env and fill in real values
# ============================================================

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/underwriting_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis (BullMQ Queue + Cache) ─────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── Internal JWT Secret ───────────────────────────────────────
JWT_SECRET=change-me-to-a-strong-secret-in-production
JWT_EXPIRES_IN=1h

# ── API-001: CIBIL TransUnion ─────────────────────────────────
CIBIL_BASE_URL=https://api.cibil.com/v2
CIBIL_CLIENT_ID=your-cibil-client-id
CIBIL_CLIENT_SECRET=your-cibil-client-secret
CIBIL_TOKEN_URL=https://api.cibil.com/oauth/token
CIBIL_TIMEOUT_MS=10000
CIBIL_MAX_RETRIES=3

# ── API-003: Experian (Fallback Bureau) ───────────────────────
EXPERIAN_BASE_URL=https://api.experian.co.in/v1
EXPERIAN_API_KEY=your-experian-api-key
EXPERIAN_TIMEOUT_MS=10000

# ── API-004: PAN KYC (NSDL/Protean) ──────────────────────────
PAN_KYC_BASE_URL=https://api.protean.co.in/v1
PAN_KYC_API_KEY=your-pan-kyc-api-key
PAN_KYC_TIMEOUT_MS=5000

# ── API-005: Aadhaar eKYC (UIDAI) ────────────────────────────
AADHAAR_BASE_URL=https://api.uidai.gov.in/kyc/v1
AADHAAR_AUA_CODE=your-aua-code
AADHAAR_AUA_KEY=your-aua-key
AADHAAR_ASA_LICENSE_KEY=your-asa-license-key
AADHAAR_TIMEOUT_MS=8000

# ── API-006: Account Aggregator (Finvu) ───────────────────────
AA_BASE_URL=https://api.finvu.in/v2
AA_CLIENT_ID=your-aa-client-id
AA_CLIENT_SECRET=your-aa-client-secret
AA_FIU_ID=your-fiu-id
AA_TIMEOUT_MS=35000
AA_POLL_INTERVAL_MS=5000
AA_MAX_POLLS=6

# ── API-007: Bank Statement Analysis (Perfios) ────────────────
PERFIOS_BASE_URL=https://api.perfios.com/v1
PERFIOS_API_KEY=your-perfios-api-key
PERFIOS_TIMEOUT_MS=15000

# ── API-008: ITR Verification (NSDL) ─────────────────────────
ITR_BASE_URL=https://api.nsdl.co.in/itr/v1
ITR_API_KEY=your-itr-api-key
ITR_TIMEOUT_MS=8000

# ── API-009: Appography SDK (IDfy) ───────────────────────────
APPOGRAPHY_BASE_URL=https://api.idfy.com/v1
APPOGRAPHY_API_KEY=your-idfy-api-key
APPOGRAPHY_TIMEOUT_MS=5000

# ── API-010: SMS Analysis (Finarkein) ────────────────────────
SMS_BASE_URL=https://api.finarkein.com/v1
SMS_API_KEY=your-finarkein-api-key
SMS_TIMEOUT_MS=5000

# ── API-011: Telecom / WhatsApp Vintage (TRAI MNP) ───────────
TELECOM_BASE_URL=https://api.trai.gov.in/mnp/v1
TELECOM_API_KEY=your-trai-api-key
TELECOM_TIMEOUT_MS=5000

# ── API-012: Location / Google Maps ──────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-key
LOCATION_INTERNAL_BASE_URL=http://location-service:3001/v1
LOCATION_TIMEOUT_MS=3000

# ── API-013: PIN Code Risk (Internal) ────────────────────────
PIN_RISK_BASE_URL=http://pin-risk-service:3002/v1
PIN_RISK_TIMEOUT_MS=1000

# ── API-014: Employer Verification (Karza) ───────────────────
EMPLOYER_BASE_URL=https://api.karza.in/v3
EMPLOYER_API_KEY=your-karza-api-key
EMPLOYER_TIMEOUT_MS=8000

# ── API-015: NACH / Mandate Check (Razorpay) ─────────────────
NACH_BASE_URL=https://api.razorpay.com/v1
NACH_KEY_ID=your-razorpay-key-id
NACH_KEY_SECRET=your-razorpay-key-secret
NACH_TIMEOUT_MS=5000

# ── API-016: Fraud Blacklist (Internal) ──────────────────────
FRAUD_BLACKLIST_BASE_URL=http://fraud-service:3003/v1
FRAUD_BLACKLIST_TIMEOUT_MS=1000

# ── API-018: Pricing Engine (Internal) ───────────────────────
PRICING_ENGINE_BASE_URL=http://pricing-service:3004/v1
PRICING_TIMEOUT_MS=1000

# ── API-019: Consent Ledger (Internal) ───────────────────────
CONSENT_LEDGER_BASE_URL=http://consent-service:3005/v1
CONSENT_TIMEOUT_MS=1000

# ── API-020: Audit Log ────────────────────────────────────────
AUDIT_LOG_BASE_URL=http://audit-service:3006/v1
AUDIT_TIMEOUT_MS=500

# ── Rule Engine ───────────────────────────────────────────────
RULES_DIRECTORY=./rules
RULES_RELOAD_INTERVAL_MS=60000

# ── Rate Limits ───────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Business Config ───────────────────────────────────────────
BASE_INTEREST_RATE=10.50
MAX_LOAN_AMOUNT=2500000
MIN_LOAN_AMOUNT=50000
MAX_TENURE_MONTHS=60
MIN_TENURE_MONTHS=12
MAX_FOIR=0.65
